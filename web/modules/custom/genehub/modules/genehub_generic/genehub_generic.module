<?php

/**
 * @file
 * Provides integration hooks for the GeneHub Generic Product module.
 */

declare(strict_types=1);

use Drupal\Core\Access\AccessResult;
use Drupal\Core\Cache\RefinableCacheableDependencyInterface;
use Drupal\Core\Entity\ContentEntityInterface;
use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Language\LanguageInterface;
use Drupal\Core\Session\AccountInterface;
use Drupal\jsonapi\JsonApiFilter;

/**
 * Implements hook_gin_content_form_routes().
 */
function genehub_generic_gin_content_form_routes(): array {
  return [
    'entity.product_generic.add_form',
    'entity.product_generic.edit_form',
    'entity.product_generic.content_translation_add',
    'entity.product_generic.content_translation_edit',
  ];
}

/**
 * Implements hook_page_attachments().
 */
function genehub_generic_page_attachments(array &$attachments): void {
  $route_name = \Drupal::routeMatch()->getRouteName();
  $admin_form_routes = [
    'entity.product_generic.add_form',
    'entity.product_generic.edit_form',
    'entity.product_generic.content_translation_add',
    'entity.product_generic.content_translation_edit',
  ];

  if (is_string($route_name) && in_array($route_name, $admin_form_routes, TRUE)) {
    $attachments['#attached']['library'][] = 'genehub/admin_form';
  }
}

/**
 * Implements hook_menu_local_tasks_alter().
 */
function genehub_generic_menu_local_tasks_alter(&$data, $route_name, RefinableCacheableDependencyInterface &$cacheability): void {
  if (!is_string($route_name) || !str_starts_with($route_name, 'entity.product_generic.')) {
    return;
  }

  $product = _genehub_generic_route_product();
  if (!$product || $product->isNew() || !$product->access('update')) {
    return;
  }

  $languages = \Drupal::languageManager()->getLanguages();
  if (count($languages) < 2) {
    return;
  }

  $stored_product = \Drupal::entityTypeManager()
    ->getStorage($product->getEntityTypeId())
    ->load($product->id());
  if (!$stored_product instanceof ContentEntityInterface) {
    return;
  }

  $translations = $stored_product->getTranslationLanguages();
  $current_langcode = _genehub_generic_current_form_langcode($stored_product);
  $source_langcode = _genehub_generic_source_langcode($translations, $current_langcode, $stored_product->getUntranslated()->language()->getId());
  $weight = 1000;

  $data['tabs'][0]['genehub_generic.language_spacer'] = [
    '#markup' => '<li class="tabs__tab genehub-language-local-task-spacer" aria-hidden="true"></li>',
    '#weight' => $weight++,
  ];

  foreach ($languages as $langcode => $language) {
    $translated = isset($translations[$langcode]);
    $active = $langcode === $current_langcode;
    $url = $translated
      ? $stored_product->toUrl('edit-form', ['language' => $language])
      : $stored_product->toUrl('drupal:content-translation-add', ['language' => $language])
        ->setRouteParameter('source', $source_langcode)
        ->setRouteParameter('target', $langcode);

    $data['tabs'][0]['genehub_generic.language.' . $langcode] = [
      '#theme' => 'menu_local_task',
      '#link' => [
        'title' => ($translated ? '' : '+') . strtoupper($langcode),
        'url' => $url,
        'localized_options' => [
          'attributes' => [
            'class' => [
              'genehub-language-local-task',
              $active ? 'is-active' : 'is-inactive',
            ],
            'title' => $translated
              ? t('Edit @language translation', ['@language' => $language->getName()])
              : t('Add @language translation', ['@language' => $language->getName()]),
          ],
        ],
      ],
      '#weight' => $weight++,
      '#active' => $active,
    ];
  }

  $cacheability->addCacheableDependency($stored_product);
  $cacheability->addCacheContexts([
    'route',
    'user.permissions',
  ]);
  $cacheability->addCacheTags(['config:configurable_language_list']);
}

/**
 * Gets the generic product from the current route.
 */
function _genehub_generic_route_product(): ?ContentEntityInterface {
  $product = \Drupal::routeMatch()->getParameter('product_generic');
  return $product instanceof ContentEntityInterface ? $product : NULL;
}

/**
 * Resolves the active form language from route parameters.
 */
function _genehub_generic_current_form_langcode(ContentEntityInterface $product): string {
  $route_match = \Drupal::routeMatch();
  foreach (['target', 'language'] as $parameter_name) {
    $language = $route_match->getParameter($parameter_name);
    if ($language instanceof LanguageInterface) {
      return $language->getId();
    }
  }

  $content_langcode = \Drupal::languageManager()
    ->getCurrentLanguage(LanguageInterface::TYPE_CONTENT)
    ->getId();
  if ($product->hasTranslation($content_langcode)) {
    return $content_langcode;
  }

  return $product->language()->getId();
}

/**
 * Resolves the source language for new translation tabs.
 */
function _genehub_generic_source_langcode(array $translations, string $current_langcode, string $default_langcode): string {
  $source = \Drupal::routeMatch()->getParameter('source');
  if ($source instanceof LanguageInterface && isset($translations[$source->getId()])) {
    return $source->getId();
  }

  if (isset($translations[$current_langcode])) {
    return $current_langcode;
  }

  return $default_langcode;
}

/**
 * Implements hook_jsonapi_product_generic_filter_access().
 */
function genehub_generic_jsonapi_product_generic_filter_access(EntityTypeInterface $entity_type, AccountInterface $account): array {
  $published_access = AccessResult::allowedIfHasPermission($account, 'access content')
    ->addCacheableDependency($entity_type)
    ->cachePerPermissions();

  $admin_access = AccessResult::allowedIfHasPermission($account, 'administer generic products')
    ->addCacheableDependency($entity_type)
    ->cachePerPermissions();

  return [
    JsonApiFilter::AMONG_PUBLISHED => $published_access->orIf($admin_access),
    JsonApiFilter::AMONG_ALL => $admin_access,
  ];
}
